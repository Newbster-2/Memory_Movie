## HALOGRAM CATEGORIES: albedo self_illumination blend_mode misc warp overlay edge_fade distortion soft_fade

## Opaque texture camera shader with self illumination plus function color change
## 0 4 0 0 0 0 0 0 0
GenerateShader halogram default from_diffuse opaque first_person_never none none none off off

CreateTag rmhg objects\eldewrito\reforge\shaders\opaque_texture_camera
EditTag objects\eldewrito\reforge\shaders\opaque_texture_camera.shader_halogram

SetField BaseRenderMethod shaders\halogram.render_method_definition

AddBlockElements Options 9
SetField Options[1].OptionIndex 4

AddBlockElements ShaderProperties
SetField ShaderProperties[0].Template shaders\halogram_templates\_0_4_0_0_0_0_0_0_0.render_method_template

AddBlockElements ShaderProperties[0].RealConstants 5
SetArgument base_map 1 1 0 0
SetArgument detail_map 1 1 0 0
SetArgument albedo_color 1 1 1 1
SetArgument self_illum_color 1 1 1 1
SetArgument self_illum_intensity 3 0 0 0

AddBlockElements ShaderProperties[0].TextureConstants 2
SetBitmap base_map shaders\default_bitmaps\bitmaps\color_white.bitmap
SetBitmap detail_map shaders\default_bitmaps\bitmaps\default_detail.bitmap
SetField ShaderProperties[0].TextureConstants[0].ExternTextureMode TextureCamera
SetField ShaderProperties[0].TextureConstants[1].TextureTransformConstantIndex 1

AddBlockElements ShaderProperties[0].Functions
SetField ShaderProperties[0].Functions[*].Type ChangeColorPrimary
SetField ShaderProperties[0].Functions[*].Function.Data 01340100FFFFFF000000000000000000FFFFFFFF000000000000000000000000

AddFunction self_illum_color Real 0

SetField RenderFlags IgnoreFog
SetField SortLayer Normal
SetField PredictionAtomIndex -1

SaveTagChanges
Exit

## Ditto for scope camera
DuplicateTag objects\eldewrito\reforge\shaders\opaque_texture_camera.shader_halogram objects\eldewrito\reforge\shaders\opaque_scope_camera
EditTag objects\eldewrito\reforge\shaders\opaque_scope_camera.shader_halogram
SetField ShaderProperties[0].TextureConstants[0].ExternTextureMode Scope
SaveTagChanges
Exit

## Ditto for z camera
DuplicateTag objects\eldewrito\reforge\shaders\opaque_texture_camera.shader_halogram objects\eldewrito\reforge\shaders\opaque_z_camera
EditTag objects\eldewrito\reforge\shaders\opaque_z_camera.shader_halogram
SetField ShaderProperties[0].TextureConstants[0].ExternTextureMode ZCamera
SetField RenderFlags IgnoreFog,UsesDepthCamera
SaveTagChanges
Exit

