## Additive constant color shader with self illumination and soft fade plus function color change
## 2 4 1 0 0 0 0 0 1
GenerateShader halogram constant_color from_diffuse additive first_person_never none none none off on

CreateTag rmhg objects\eldewrito\reforge\shaders\ghost_paint
EditTag objects\eldewrito\reforge\shaders\ghost_paint.shader_halogram

SetField BaseRenderMethod shaders\halogram.render_method_definition

AddBlockElements Options 9
SetField Options[0].OptionIndex 2
SetField Options[1].OptionIndex 4
SetField Options[2].OptionIndex 1
SetField Options[8].OptionIndex 1

AddBlockElements ShaderProperties
SetField ShaderProperties[0].Template shaders\halogram_templates\_2_4_1_0_0_0_0_0_1.render_method_template

AddBlockElements ShaderProperties[0].RealConstants 7
SetArgument albedo_color 1 1 1 1
SetArgument self_illum_color 1 1 1 1
SetArgument self_illum_intensity 3 0 0 0
SetArgument use_soft_fresnel 0 0 0 0
SetArgument soft_fresnel_power 0 0 0 0
SetArgument use_soft_z 1 0 0 0
SetArgument soft_z_range 0.1 0 0 0
SetArgument Booleans use_soft_z

AddBlockElements ShaderProperties[0].Functions
SetField ShaderProperties[0].Functions[*].Type ChangeColorPrimary
SetField ShaderProperties[0].Functions[*].Function.Data 01340100FFFFFF000000000000000000FFFFFFFF000000000000000000000000

AddFunction self_illum_color Real 0

SetField ShaderProperties[0].BlendMode Additive

SetField SortLayer Normal
SetField PredictionAtomIndex -1

SaveTagChanges
Exit

## Ditto for no fog
DuplicateTag objects\eldewrito\reforge\shaders\ghost_paint.shader_halogram objects\eldewrito\reforge\shaders\ghost_paint_no_fog
EditTag objects\eldewrito\reforge\shaders\ghost_paint_no_fog.shader_halogram
SetField RenderFlags IgnoreFog
SaveTagChanges
Exit

## Ditto for more soft fade
DuplicateTag objects\eldewrito\reforge\shaders\ghost_paint.shader_halogram objects\eldewrito\reforge\shaders\backdrop_paint
EditTag objects\eldewrito\reforge\shaders\backdrop_paint.shader_halogram
SetArgument soft_z_range 0.01 0 0 0
SaveTagChanges
Exit

## Ditto for no fog
DuplicateTag objects\eldewrito\reforge\shaders\backdrop_paint.shader_halogram objects\eldewrito\reforge\shaders\backdrop_paint_no_fog
EditTag objects\eldewrito\reforge\shaders\backdrop_paint_no_fog.shader_halogram
SetField RenderFlags IgnoreFog
SaveTagChanges
