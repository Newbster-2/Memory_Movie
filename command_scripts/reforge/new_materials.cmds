SetArgument self_illum_color 1 1 1 1
SetArgument self_illum_intensity 3 0 0 0

AddBlockElements ShaderProperties[0].TextureConstants 2
SetBitmap base_map shaders\default_bitmaps\bitmaps\color_white.bitmap
SetBitmap detail_map shaders\default_bitmaps\bitmaps\default_detail.bitmap
SetField ShaderProperties[0].TextureConstants[0].ExternTextureMode ZCamera
SetField ShaderProperties[0].TextureConstants[1].TextureTransformConstantIndex 1

AddBlockElements ShaderProperties[0].Functions
